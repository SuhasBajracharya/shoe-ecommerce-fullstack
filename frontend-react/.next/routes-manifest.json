{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [
      {
        "source": "/api/:path*",
        "destination": "http://localhost:8000/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "afterFiles": [],
    "fallback": [
      {
        "source": "/login",
        "destination": "http://localhost:8000/login",
        "regex": "^/login(?:/)?$"
      },
      {
        "source": "/register",
        "destination": "http://localhost:8000/register",
        "regex": "^/register(?:/)?$"
      },
      {
        "source": "/logout",
        "destination": "http://localhost:8000/logout",
        "regex": "^/logout(?:/)?$"
      },
      {
        "source": "/products",
        "destination": "http://localhost:8000/products",
        "regex": "^/products(?:/)?$"
      },
      {
        "source": "/product/:path*",
        "destination": "http://localhost:8000/product/:path*",
        "regex": "^/product(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      },
      {
        "source": "/add-review",
        "destination": "http://localhost:8000/add-review",
        "regex": "^/add-review(?:/)?$"
      },
      {
        "source": "/admin/reviews",
        "destination": "http://localhost:8000/admin/reviews",
        "regex": "^/admin/reviews(?:/)?$"
      },
      {
        "source": "/api/check-session",
        "destination": "http://localhost:8000/api/check-session",
        "regex": "^/api/check-session(?:/)?$"
      }
    ]
  },
  "dynamicRoutes": [
    {
      "page": "/product/[productId]",
      "regex": "^/product/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPproductId": "nxtPproductId"
      },
      "namedRegex": "^/product/(?<nxtPproductId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
